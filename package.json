{
  "name": "lufthaven",
  "version": "0.1.4",
  "description": "Flight data MCP server + CLI. Real-time flight tracking, airport weather, deals, and TSA wait times for AI agents and developers.",
  "type": "module",
  "bin": {
    "lufthaven": "./dist/cli/index.js",
    "lufthaven-mcp": "./dist/mcp/stdio.js"
  },
  "main": "./dist/mcp/server.js",
  "exports": {
    ".": "./dist/mcp/server.js",
    "./api": "./dist/api/client.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:mcp": "node --import tsx src/mcp/stdio.ts",
    "dev:cli": "node --import tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "mcp",
    "flight",
    "aviation",
    "adsb",
    "flight-tracking",
    "airport",
    "weather",
    "tsa",
    "chatgpt",
    "claude",
    "ai-agent",
    "cli"
  ],
  "author": "Lufthaven",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lufthaven/lufthaven-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.1"
  }
}
